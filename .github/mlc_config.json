{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://localhost"
    },
    {
      "pattern": "^http://127.0.0.1"
    },
    {
      "pattern": "^https://127.0.0.1"
    },
    {
      "pattern": "^javascript:"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "^{{.*}}$"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^l([0-9][^/]*)/$",
      "replacement": "l$1.md"
    },
    {
      "pattern": "^proposals/(AILIS_[^/]+)/$",
      "replacement": "proposals/$1.md"
    },
    {
      "pattern": "^FEEDBACK/$",
      "replacement": "FEEDBACK.md"
    },
    {
      "pattern": "^website-workflows/$",
      "replacement": "website-workflows.md"
    },
    {
      "pattern": "^\\.\\./\\.\\./layers/([^/]+)/$",
      "replacement": "../docs/layers/$1.md"
    }
  ],
  "httpStatusCodes": [200, 201, 202, 204, 206, 300, 301, 302, 303, 304, 307, 308],
  "timeout": "30s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackHttpStatusCodes": [400, 401, 403, 404, 429, 500, 502, 503, 504],
  "aliveStatusCodes": [200, 206, 300, 301, 302, 303, 304, 307, 308, 403]
}
